# Credentials / secrets
.credentials
.credentials.json

# Runtime artifacts (regenerate on their own)
.context
.local/
node_modules/
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.tmp/
dist/

# Entity GPG keyring — private keys, never commit
keyring/

# Claude Code plugins (upstream marketplace cache, not entity-owned)
plugins/

# Claude Code session artifacts (regenerated per session)
backups/
debug/
file-history/
image-cache/
paste-cache/
sessions/
shell-snapshots/
tasks/
test-results/
tooltips/
history.jsonl
projects

# Runtime state — statusline probe dumps, session telemetry, pulse log
state/

# Generated media (lives in ~/.forge/brand-assets/)
media/

# Flight process state — machine-local, ephemeral
# Durable history lives in the commit's `Flight-id:` trailer
control/flights/*.json

# Flight plans — ephemeral dispatch artifacts (durable record is commit trailer)
flight-plans/

# Claude Code harness artifacts (regenerated per session)
.claude.json
.claude/
mcp-needs-auth-cache.json

# Runtime state
var/
